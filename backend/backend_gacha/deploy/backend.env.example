# 운영 서버에서 /etc/gacha-scheduler/backend.env 로 배치할 실제 값 템플릿.
# 이 파일 자체(backend.env.example)는 값이 없어 커밋해도 되지만,
# 실제 값이 채워진 backend.env는 절대 커밋하지 말 것(서버에만 존재해야 함, 권한 600 권장).

# Cloud DB for PostgreSQL(또는 서버에 직접 설치한 Postgres) 엔드포인트로 교체 (로컬 개발과 동일한 키, 값만 교체)
DB_URL=jdbc:postgresql://<db-endpoint>:5432/gacha_scheduler
DB_USERNAME=<db-username>
DB_PASSWORD=<db-password>

# 프론트(VITE_GOOGLE_CLIENT_ID)와 동일한 값
GOOGLE_CLIENT_ID=<google-oauth-client-id>

# openssl rand -base64 48 로 생성 — 로컬 개발용과 별개로 운영 전용 값을 새로 발급할 것
JWT_SECRET=<random-secret-at-least-32-bytes>

# 배포된 프론트 도메인(들), 콤마로 구분. mobile_shell을 원격 URL 모드로 쓰면 그 origin도 추가
CORS_ALLOWED_ORIGINS=https://<your-deployed-domain>

# NCP 콘솔 > Object Storage 버킷 + 마이페이지 > 인증키 관리에서 발급한 API 인증키(이미지 업로드용)
NCP_OBJECT_STORAGE_BUCKET=<bucket-name>
NCP_OBJECT_STORAGE_ACCESS_KEY=<ncp-access-key>
NCP_OBJECT_STORAGE_SECRET_KEY=<ncp-secret-key>
