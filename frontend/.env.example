# 이 파일을 .env 로 복사한 뒤 실제 값을 채운다. .env 는 gitignore 대상이다.

VITE_API_BASE_URL=http://localhost:8080
VITE_GOOGLE_CLIENT_ID=<google-oauth-client-id>

# 가챠 시뮬레이터: 기본은 실 API. 백엔드 없이 UI만 볼 때만 true(Mock 동작)로 변경
VITE_USE_MOCK_GACHA=false

# 모바일 앱 셸(Capacitor)은 Google이 임베디드 WebView를 차단해서 로그인을 외부 브라우저로 위임한다.
# 그 브라우저가 열어야 할 이 웹앱의 주소(실기기는 `adb reverse tcp:5173 tcp:5173` 필요, 배포 시엔 실 도메인으로 교체)
VITE_OAUTH_BRIDGE_URL=http://localhost:5173
